    {"mode":"managed","type":"google_compute_instance","name":"bastion","instances":[{"attributes":{"id":"projects/proj-dmz/zones/us-central1-a/instances/bastion-01","name":"bastion-01","project":"proj-dmz","network_interface":[{"network":"projects/proj-dmz/global/networks/dmz","subnetwork":"projects/proj-dmz/regions/us-central1/subnetworks/dmz","network_ip":"10.0.1.10","access_config":[{"nat_ip":"203.0.113.10"}]}],"service_account":[{"email":"bastion@proj-dmz.iam.gserviceaccount.com"}]}}]},
    {"mode":"managed","type":"google_cloud_run_v2_service","name":"api","instances":[{"attributes":{"id":"projects/proj-app/locations/us-central1/services/app-api","name":"app-api","project":"proj-app","template":[{"service_account":"cloudbuild@proj-shared.iam.gserviceaccount.com"}]}}]},
    {"mode":"managed","type":"google_storage_bucket","name":"pci_exports","instances":[{"attributes":{"name":"corp-pci-crown-jewel","project":"proj-pci"}}]},
    {"mode":"managed","type":"google_secret_manager_secret","name":"prod_db","instances":[{"attributes":{"project":"proj-pci","secret_id":"prod-db-password"}}]},
    {"mode":"managed","type":"google_service_account_iam_member","name":"build_impersonates_pci","instances":[{"attributes":{"project":"proj-pci","service_account_id":"pci-reader@proj-pci.iam.gserviceaccount.com","member":"serviceAccount:cloudbuild@proj-shared.iam.gserviceaccount.com","role":"roles/iam.serviceAccountTokenCreator"}}]},
    {"mode":"managed","type":"google_iam_workload_identity_pool","name":"github","instances":[{"attributes":{"project":"proj-shared","id":"projects/proj-shared/locations/global/workloadIdentityPools/github","workload_identity_pool_id":"github"}}]},
    {"mode":"managed","type":"google_iam_workload_identity_pool_provider","name":"github_oidc","instances":[{"attributes":{"project":"proj-shared","id":"projects/proj-shared/locations/global/workloadIdentityPools/github/providers/github-oidc"}}]}
  ]
