    {"mode":"managed","type":"google_compute_network","name":"app","instances":[{"attributes":{"id":"projects/proj-app/global/networks/app","name":"app","project":"proj-app","ipv4_range":"10.10.0.0/16"}}]},
    {"mode":"managed","type":"google_compute_network","name":"pci","instances":[{"attributes":{"id":"projects/proj-pci/global/networks/pci","name":"pci","project":"proj-pci","ipv4_range":"10.20.0.0/16"}}]},
    {"mode":"managed","type":"google_compute_network","name":"shared","instances":[{"attributes":{"id":"projects/proj-shared/global/networks/shared","name":"shared","project":"proj-shared","ipv4_range":"10.30.0.0/16"}}]},
    {"mode":"managed","type":"google_compute_network","name":"staging","instances":[{"attributes":{"id":"projects/proj-staging/global/networks/staging","name":"staging","project":"proj-staging","ipv4_range":"10.40.0.0/16"}}]},
    {"mode":"managed","type":"google_compute_subnetwork","name":"dmz_subnet","instances":[{"attributes":{"project":"proj-dmz","network":"projects/proj-dmz/global/networks/dmz","ip_cidr_range":"10.0.1.0/24"}}]},
    {"mode":"managed","type":"google_compute_firewall","name":"bastion_ingress","instances":[{"attributes":{"project":"proj-dmz","name":"bastion-ingress","network":"projects/proj-dmz/global/networks/dmz","source_ranges":["0.0.0.0/0"],"allow":[{"protocol":"tcp","ports":["22"]}]}}]},
    {"mode":"managed","type":"google_compute_network_peering","name":"dmz_app","instances":[{"attributes":{"id":"dmz-app","project":"proj-dmz","network":"projects/proj-dmz/global/networks/dmz","peer_network":"projects/proj-app/global/networks/app","state":"ACTIVE"}}]},
    {"mode":"managed","type":"google_compute_network_peering","name":"app_pci","instances":[{"attributes":{"id":"app-pci","project":"proj-app","network":"projects/proj-app/global/networks/app","peer_network":"projects/proj-pci/global/networks/pci","state":"ACTIVE"}}]},
    {"mode":"managed","type":"google_service_account","name":"bastion","instances":[{"attributes":{"project":"proj-dmz","email":"bastion@proj-dmz.iam.gserviceaccount.com"}}]},
    {"mode":"managed","type":"google_service_account","name":"cloudbuild","instances":[{"attributes":{"project":"proj-shared","email":"cloudbuild@proj-shared.iam.gserviceaccount.com"}}]},
